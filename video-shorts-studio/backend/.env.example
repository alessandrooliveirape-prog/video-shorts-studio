# 🆓 Shorts Studio — Configuração 100% Gratuita
# ==============================================
# NENHUMA API PAGA É NECESSÁRIA!
#
# Groq Cloud (API gratuita, sem cartão de crédito):
#   - Cadastre-se: https://console.groq.com
#   - Crie sua API Key: https://console.groq.com/keys
#
# Pexels (API gratuita, sem cartão de crédito):
#   - Cadastre-se: https://www.pexels.com/api/
#   - Crie sua API Key gratuita para B-roll automático
#
# Mesmo sem configurar as chaves, o app funciona em modo simulado!

GROQ_API_KEY=
PEXELS_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
HOST=0.0.0.0
PORT=8000
