{
  "name": "video-shorts-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:frontend": "vitest run",
    "test:backend": "cd backend && python test_dozero_flow.py",
    "test:all": "npm run lint && npm run test:frontend && npm run test:backend",
    "backend": "cd backend && python -m uvicorn fastapi_backend:app --reload --port 8000 --host 0.0.0.0",
    "setup": "bash backend/setup.sh"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tsx": "^4.23.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vitest": "^4.1.10"
  }
}
